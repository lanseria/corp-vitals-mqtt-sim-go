# ==========================================
# 模拟器环境配置文件 (.env)
# ==========================================

# 1. MQTT Broker 配置
# 对于本地测试可以使用 tcp://localhost:1883
# 对于 HiveMQ Cloud，通常是 tls://<your-cluster-url>:8883 (注意如果是 TLS 需要用 tls:// 协议)
MQTT_URL=tcp://localhost:1883

# MQTT 客户端 ID，必须保证在同一个 Broker 中唯一
MQTT_CLIENT_ID=corp-vitals-sim-client-001

# 2. HTTP 调试服务配置
# 模拟器提供的本地 HTTP API 端口，用于查询设备列表和动态修改设备状态
HTTP_PORT=8080